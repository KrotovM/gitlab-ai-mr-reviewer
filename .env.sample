OPENAI_API_KEY=<your OpenAI API key>
AI_MODEL=gpt-4o

# Optional: recommended for private GitLab projects (Project or Personal Access Token with scope "api")
PROJECT_ACCESS_TOKEN=<your gitlab access token>

# Optional (GitLab CI usually provides these automatically)
CI_API_V4_URL=https://gitlab.com/api/v4
CI_PROJECT_ID=<your project id>
CI_MERGE_REQUEST_IID=<your merge request iid>
# Used only when PROJECT_ACCESS_TOKEN is not set
CI_JOB_TOKEN=<your ci job token>